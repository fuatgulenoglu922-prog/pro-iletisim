// ===============================================================
// Assumed Data Model
// ===============================================================
//
// Collection: users
// Document ID: {uid}
// Fields:
//   - uid: string (required) - Firebase Auth UID
//   - displayName: string (required) - Görünen ad
//   - email: string (optional) - E-posta adresi
//   - id4: string (required) - 4 haneli benzersiz ID
//   - role: string (required, enum: ["CEO", "Leader", "User"]) - Kullanıcı rolü
//   - isPro: boolean (optional) - Pro özellik durumu
//
// Collection: messages
// Document ID: {messageId}
// Fields:
//   - senderId: string (required) - Gönderen UID
//   - receiverId: string (required) - Alıcı UID veya 'AI'
//   - text: string (required) - Mesaj içeriği
//   - timestamp: timestamp (required) - Gönderim zamanı
//
// Collection: friendships
// Document ID: {friendshipId}
// Fields:
//   - user1: string (required) - Birinci kullanıcı UID
//   - user2: string (required) - İkinci kullanıcı UID
//   - status: string (required, enum: ["pending", "accepted"]) - Arkadaşlık durumu
//
// ===============================================================

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Helper Functions
    // ===============================================================

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() && 
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['CEO', 'Leader'] ||
         (request.auth.token.email == "fuatgulenoglu922@gmail.com" && request.auth.token.email_verified == true));
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'displayName', 'id4', 'role']) &&
             data.uid is string && data.uid.size() > 0 &&
             data.displayName is string && data.displayName.size() > 0 && data.displayName.size() < 50 &&
             data.id4 is string && data.id4.matches("^\\d{4}$") &&
             data.role in ['CEO', 'Leader', 'User'];
    }

    function isValidMessage(data) {
      return data.keys().hasAll(['senderId', 'receiverId', 'text', 'timestamp']) &&
             data.senderId == request.auth.uid &&
             data.receiverId is string &&
             data.text is string && data.text.size() > 0 && data.text.size() < 5000 &&
             data.timestamp is timestamp;
    }

    function isValidFriendship(data) {
      return data.keys().hasAll(['user1', 'user2', 'status']) &&
             (data.user1 == request.auth.uid || data.user2 == request.auth.uid) &&
             data.status in ['pending', 'accepted'];
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{uid} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isOwner(uid) && isValidUser(request.resource.data) && 
                      (request.resource.data.role == 'User' || isAdmin());
      allow update: if isAuthenticated() && (isOwner(uid) || isAdmin()) && 
                      isValidUser(request.resource.data) &&
                      (request.resource.data.role == resource.data.role || isAdmin());
      allow delete: if isAdmin();
    }

    match /messages/{messageId} {
      allow read: if isAuthenticated() && (resource.data.senderId == request.auth.uid || resource.data.receiverId == request.auth.uid || resource.data.receiverId == 'AI');
      allow create: if isAuthenticated() && isValidMessage(request.resource.data);
      allow update, delete: if isAdmin();
    }

    match /friendships/{friendshipId} {
      allow read: if isAuthenticated() && (resource.data.user1 == request.auth.uid || resource.data.user2 == request.auth.uid);
      allow create: if isAuthenticated() && isValidFriendship(request.resource.data);
      allow update: if isAuthenticated() && (resource.data.user1 == request.auth.uid || resource.data.user2 == request.auth.uid) && isValidFriendship(request.resource.data);
      allow delete: if isAuthenticated() && (resource.data.user1 == request.auth.uid || resource.data.user2 == request.auth.uid);
    }

    // Default deny
    match /{path=**} {
      allow read, write: if false;
    }
  }
}
